# ─────────────────────────────────────────────────────────────────────────────
# Noxis environment configuration
# Copy to `.env.local` for local dev, or set these in the Vercel dashboard.
# NEVER commit a funded private key.
# ─────────────────────────────────────────────────────────────────────────────

# Funded 0G testnet wallet. Pays for 0G Storage uploads + 0G Compute inference.
# This key lives ONLY on the server (API routes). It is never sent to the browser.
ZG_PRIVATE_KEY=0xyour_testnet_private_key

# 0G Galileo testnet endpoints (defaults shown — usually no need to change).
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute provider (TEE-verifiable inference). Pick one:
#   qwen/qwen-2.5-7b-instruct  -> 0xa48f01287233509FD694a22Bf840225062E67836
#   openai/gpt-oss-20b         -> 0x8e60d466FD16798Bec4868aa4CE38586D5590049
#   google/gemma-3-27b-it      -> 0x69Eb5a0BD7d0f4bF39eD5CE9Bd3376c61863aE08
ZG_COMPUTE_PROVIDER=0xa48f01287233509FD694a22Bf840225062E67836

# Funding amounts (in OG). Contract minimums: ledger >= 3, provider >= 1.
# Fund the wallet with at least ~5 OG (3 ledger + 1 provider + gas).
ZG_LEDGER_OG=3
ZG_PROVIDER_OG=1
